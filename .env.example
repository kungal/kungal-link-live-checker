# kungal-link-live-checker — 配置示例
# 复制为 .env 并按需修改;.env 已被 .gitignore 挡掉,密钥绝不入库。
# 所有变量都有默认值;最少只需设置 LLC_API_KEYS 即可启动。

# 监听地址
LLC_ADDR=:8080

# s2s 鉴权:逗号分隔的 API key(每个消费方一把)。
# 留空 = 拒绝一切 /v1 请求(fail-closed,服务绝不匿名开放)。
LLC_API_KEYS=replace-with-a-long-random-key,another-consumer-key

# 单次校验超时(超时 => unknown/timeout,绝不挂住调用方)
LLC_CHECK_TIMEOUT=8s

# 批量端点单次最大条数
LLC_BATCH_MAX=50

# 缓存 TTL:dead 长、alive 中、unknown 默认不缓存(0 = 不缓存)
LLC_CACHE_TTL_ALIVE=12h
LLC_CACHE_TTL_DEAD=168h
LLC_CACHE_TTL_UNKNOWN=0s

# 按 provider 的令牌桶限流(保护出口 IP 不被网盘封)
LLC_RATE_RPS=5
LLC_RATE_BURST=5

# 夸克 41031「分享受限/被封」如何判定:
#   true  = dead/share_blocked(默认)
#   false = 降级为 unknown(更保守)
LLC_QUARK_BLOCKED_AS_DEAD=true

# UC 网盘:已实测验证(pc-api.uc.cn,夸克同源),默认开启。
LLC_UC_ENABLED=true
LLC_UC_TOKEN_URL=https://pc-api.uc.cn/1/clouddrive/share/sharepage/token?pr=UCBrowser&fr=pc

# 百度网盘:走 shorturlinfo(自动拿 BAIDUID cookie,无需登录),默认开启。
# 百度反爬较凶,若被限流可调低 LLC_RATE_RPS。
LLC_BAIDU_ENABLED=true

# 和彩云(caiyun.139.com)、123盘(123pan 系):均已实测验证,默认开启。
LLC_CAIYUN_ENABLED=true
LLC_PAN123_ENABLED=true
# 注:迅雷(pan.xunlei.com)需设备签名+验证码+登录,暂未实现,迅雷链接一律 unknown。
